{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Nxtrive",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "os:default",
    "fs:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "python",
          "cmd": "python",
          "args": true
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "nxtrive-backend",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "python",
          "cmd": "python"
        },
        {
          "name": "python3",
          "cmd": "python3"
        },
        {
          "name": "nxtrive-backend",
          "sidecar": true
        }
      ]
    }
  ]
}
